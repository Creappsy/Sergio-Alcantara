# MCP Server - Variables de Entorno
# Copiar a .env y completar con tus valores

# ===========================================
# BACKBLAZE B2 (Opcional - solo si usas uploads)
# ===========================================
B2_KEY_ID=tu_key_id_de_backblaze
B2_APPLICATION_KEY=tu_application_key_de_backblaze
B2_BUCKET_NAME=creappsy

# ===========================================
# GOFILE (Opcional - backup para uploads)
# ===========================================
GOFILE_TOKEN=tu_token_de_gofile
GOFILE_FOLDER_ID=tu_folder_id_de_gofile

# ===========================================
# CONFIGURACIÓN DEL SERVIDOR
# ===========================================
PORT=3000
NODE_ENV=development
