# ============================================
# Creappsy Form - Environment Variables
# ============================================

# --------------------------------------------
# SERVER-SIDE ONLY (API Routes)
# These are used in app/api/* and are NOT exposed to the browser
# --------------------------------------------

# Web3Forms (required for email submission)
# Get your key from: https://web3forms.com/
WEB3FORMS_KEY=your_web3forms_key_here
EMAIL_DESTINO=19roi89@gmail.com

# Backblaze B2 (optional - for file uploads)
# Get credentials from: https://www.backblaze.com/b2/cloud-storage.html
B2_KEY_ID=your_b2_key_id
B2_APPLICATION_KEY=your_b2_application_key
B2_BUCKET_NAME=creappsy

# GoFile (optional - backup for file uploads)
# Get token from: https://gofile.io/
GOFILE_TOKEN=your_gofile_token
GOFILE_FOLDER_ID=your_gofile_folder_id

# --------------------------------------------
# CLIENT-SIDE (Browser)
# These MUST start with NEXT_PUBLIC_ to be accessible in the browser
# --------------------------------------------

# Same values as server-side (for client-side validation/display)
NEXT_PUBLIC_WEB3FORMS_KEY=your_web3forms_key_here
NEXT_PUBLIC_EMAIL_DESTINO=19roi89@gmail.com

# Rate limiting settings
NEXT_PUBLIC_MAX_ATTEMPTS=5
NEXT_PUBLIC_BLOCK_DURATION_MS=900000

# Backblaze bucket name (for client-side reference)
NEXT_PUBLIC_B2_BUCKET_NAME=creappsy
